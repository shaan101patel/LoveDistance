# Copy to .env and fill in values (never commit .env).
# Reference: ../../docs/ENVIRONMENT.md

# mock = in-memory mock services | supabase = real backend (requires URL + anon key below)
EXPO_PUBLIC_API_MODE=mock

# Required when EXPO_PUBLIC_API_MODE=supabase — from Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mailto targets for Settings → Send feedback / Delete account (`getSupportEmail()`; override default)
EXPO_PUBLIC_SUPPORT_EMAIL=
